#!/usr/bin/env lua
package.path = table.concat({
  "src/?.lua",
  "src/?/init.lua",
  package.path,
}, ";")
local main = require("mutate4lua.main")
local handle = assert(io.popen("pwd", "r"))
local cwd = handle:read("*l")
handle:close()
local exit_code = main.run(arg, cwd, io.stdout, io.stderr)
os.exit(exit_code)
